# ─── Environment ───────────────────────────────────────────
# PostgreSQL connection string (Neon or local)
DATABASE_URL=postgresql://user:password@localhost:5432/codevector

# Server port
PORT=3000

# Environment
NODE_ENV=development

# ─── Seeding ───────────────────────────────────────────────
# Batch size for bulk inserts (default: 5000)
BATCH_SIZE=5000
