{
  "name": "codevector-product-browser",
  "version": "1.0.0",
  "description": "High-performance product browsing backend with cursor-based pagination for 200K+ products",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node src/db/migrate.js",
    "seed": "node scripts/seed-products.js",
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest tests/unit --forceExit",
    "test:integration": "jest tests/integration --runInBand --forceExit"
  },
  "keywords": ["pagination", "keyset", "cursor", "products", "express", "postgresql"],
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  }
}
